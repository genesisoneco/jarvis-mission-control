# Strong shared secret required for any non-local access.
MISSION_CONTROL_ACCESS_TOKEN=replace-with-a-long-random-secret

# Optional: public/browser origin used when the app is exposed through HTTPS.
# Example: https://mission-control.example.com
MISSION_CONTROL_PUBLIC_ORIGIN=

# Optional: cookie name override.
MISSION_CONTROL_COOKIE_NAME=mission_control_session

# Optional: hard-disable localhost bypass when no token is configured.
MISSION_CONTROL_DISABLE_LOCAL_BYPASS=false

# Optional: build the frontend for a non-root path.
# GitHub Pages preview uses /jarvis-mission-control/
VITE_BASE_PATH=/
